# Flutter / Dart
.dart_tool/
.packages
build/
.flutter-plugins
.flutter-plugins-dependencies
# app (not package): keep loose until we pin deliberately
pubspec.lock
# Generated-code policy:
#  - drift *.g.dart / freezed *.freezed.dart ARE committed (needs an explicit build_runner step;
#    committing them lets the repo build from a clean clone without that step — no CI yet).
#  - gen_l10n output is NOT committed: `flutter pub get` auto-regenerates it (generate: true), so
#    committing it just causes churn and reverts the zh strings to raw CJK. pub get is always the
#    first step after cloning anyway, so the app still builds.
lib/l10n/generated/
coverage/

# IDE
.idea/
.vscode/
*.iml

# iOS
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
**/*.xcworkspace/xcuserdata/

# Android
android/.gradle/
android/local.properties
android/key.properties
*.keystore
*.jks

# macOS
.DS_Store

# Secrets — never commit
*.env
secrets/

# Xcode SwiftPM resolved state (generated)
**/xcshareddata/swiftpm/Package.resolved
